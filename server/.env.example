# Ops-Diagnose (Vorlesen / Schlüssel / Endpunkte auf Live prüfen)
# Zufälligen langen Wert setzen — nur für manuelle Server-Prüfung
OSG_OPS_CHECK_TOKEN=
# OSG_OPS_RATE_MAX=30

# --- Render.com: diese Werte im Dashboard → Environment setzen (Secret) ---
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# OMNI_SECRET_KEY=
# OSG_OPS_CHECK_TOKEN=
# BRAND_TTS_CORS_ORIGIN=https://ihre-domain.onrender.com
# PORT wird von Render automatisch gesetzt

# OmniQR / HMAC (Produktion Pflicht)
# OMNI_SECRET_KEY=
# OMNI_DEV_MODE=0
# BRAND_TTS_CORS_ORIGIN=https://your-domain.example
# Engine: lokal XTTS + Live ElevenLabs-Fallback
BRAND_TTS_ENGINE=xtts
LOCAL_WEB_PORT=8080
XTTS_PORT=8788
XTTS_SERVICE_URL=http://127.0.0.1:8788

# OmniQR support tickets (optional SMTP — without SMTP, tickets land in server/omniqr-ai-for-tourist-of-thailand/data/support-outbox/)
OMNI_SUPPORT_EMAIL=support@omnisolutionsglobal.com
# OMNI_SMTP_HOST=smtp.example.com
# OMNI_SMTP_PORT=587
# OMNI_SMTP_USER=
# OMNI_SMTP_PASS=
# OMNI_SMTP_FROM=noreply@omnisolutionsglobal.com
